{
  "info": {
    "_postman_id": "e7c2d8f8-61cc-4b28-a1ce-1e3f1b8e7b2f",
    "name": "Odoo Finals Backend - TEST",
    "description": "Test collection for the current backend routes.\n\nNotes:\n- Set {{baseUrl}} (default http://localhost:3000).\n- For ADMIN login, set env vars ADMIN_EMAIL before starting the backend; the server prints the bootstrap admin password once in the console logs. Put that into {{adminPassword}}.\n- This collection uses Bearer {{accessToken}} at the collection level. Login requests save it automatically.\n- Invoice scheduler is set to run EVERY_MINUTE in this workspace for testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-add JSON header for requests with bodies",
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
          "if (pm.request.body && pm.request.body.mode === 'raw') {",
          "  pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "00 - Health",
      "item": [
        {
          "name": "Health - GET /",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/"
          }
        }
      ]
    },
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Auth - Signup (PORTAL)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Portal User\",\n  \"email\": \"{{portalEmail}}\",\n  \"password\": \"{{portalPassword}}\",\n  \"confirmPassword\": \"{{portalPassword}}\"\n}"
            }
          }
        },
        {
          "name": "Auth - Login (ADMIN) [saves accessToken]",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login returns accessToken', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('accessToken');",
                  "});",
                  "try {",
                  "  const json = pm.response.json();",
                  "  if (json && json.accessToken) pm.environment.set('accessToken', json.accessToken);",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        {
          "name": "Auth - Login (PORTAL) [saves accessToken]",
