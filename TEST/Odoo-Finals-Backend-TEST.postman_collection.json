    {
      "name": "05 - Invoices",
      "item": [
        { "name": "Invoice - List", "request": { "method": "GET", "url": "{{baseUrl}}/invoices" } },
        { "name": "Invoice - List (by subscriptionId) [sets invoiceId]", "request": { "method": "GET", "url": "{{baseUrl}}/invoices?subscriptionId={{subscriptionId}}" },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const json = pm.response.json();",
                  "  const inv = json && Array.isArray(json.data) ? json.data[0] : null;",
                  "  if (inv && inv.id != null) pm.environment.set('invoiceId', String(inv.id));",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        { "name": "Invoice - Get One (sets totals)", "request": { "method": "GET", "url": "{{baseUrl}}/invoices/{{invoiceId}}" },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "try {",
                  "  const inv = pm.response.json();",
                  "  const lines = Array.isArray(inv.lines) ? inv.lines : [];",
                  "  const payments = Array.isArray(inv.payments) ? inv.payments : [];",
                  "  const total = lines.reduce((s, l) => s + Number(l.amount || 0), 0);",
                  "  const paid = payments.reduce((s, p) => s + Number(p.amount || 0), 0);",
                  "  const outstanding = Math.max(0, Math.round((total - paid) * 100) / 100);",
                  "  pm.environment.set('invoiceTotal', String(total));",
                  "  pm.environment.set('invoiceOutstanding', String(outstanding));",
                  "} catch (e) {}"
                ]
              }
            }
          ]
        },
        { "name": "Invoice - Confirm", "request": { "method": "POST", "url": "{{baseUrl}}/invoices/{{invoiceId}}/confirm" } },
        { "name": "Invoice - Cancel", "request": { "method": "POST", "url": "{{baseUrl}}/invoices/{{invoiceId}}/cancel" } }
      ]
